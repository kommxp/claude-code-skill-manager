{
  "name": "claude-code-skill-manager",
  "version": "1.0.0",
  "description": "Local dashboard for managing, discovering, and analyzing Claude Code skills and plugins",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node server/index.js",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "setup": "npm install && cd client && npm install --legacy-peer-deps && npm run build"
  },
  "keywords": ["claude-code", "skill-manager", "plugin", "claude", "anthropic"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/claude-code-skill-manager"
  },
  "homepage": "https://github.com/your-username/claude-code-skill-manager#readme",
  "dependencies": {
    "express": "^4.21.0"
  }
}
