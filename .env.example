# Server port (default: 3200, auto-finds next available if busy)
# 服务端口（默认 3200，被占用时自动递增）
# PORT=3200

# Set to any value to disable auto-opening browser on start
# 设置任意值可禁止启动时自动打开浏览器
# NO_BROWSER=1

# Git Bash path for Windows (auto-detected if not set)
# Windows 下 Git Bash 路径（不设置则自动检测）
# CLAUDE_CODE_GIT_BASH_PATH=D:\Git\bin\bash.exe
